# ===== MySQL =====
# root 账号密码(仅本地开发使用)
MYSQL_ROOT_PASSWORD=root
# 宿主机映射端口
MYSQL_PORT=3306

# ===== Redis =====
# 宿主机映射端口
REDIS_PORT=6379

# ===== Kafka =====
# 容器内 / 容器间通信端口(INTERNAL listener)
KAFKA_PORT=9092
# 宿主机外部访问端口(EXTERNAL listener,应用在宿主机时使用)
KAFKA_EXTERNAL_PORT=29092

# ===== 可选可观测/管理工具(profile=tools) =====
# Kafka UI 访问端口
KAFKA_UI_PORT=8090
# Adminer (MySQL Web 客户端) 访问端口
ADMINER_PORT=8091
# Redis Commander 访问端口
REDIS_COMMANDER_PORT=8092
